{
  "name": "@okrapdf/cli",
  "version": "0.17.1",
  "description": "BYOK PDF parsing CLI — bring your own Gemini/NVIDIA/OpenAI-compatible key. Layout-aware markdown + bbox blocks. okraPDF cloud optional.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "okra": "./dist/index.js"
  },
  "packageManager": "pnpm@11.9.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "okrapdf",
    "pdf",
    "byok",
    "vlm",
    "layout",
    "ocr",
    "extraction",
    "cli",
    "document",
    "table-extraction",
    "ai",
    "document-processing"
  ],
  "author": "okraPDF",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/okrapdf/cli.git"
  },
  "homepage": "https://okrapdf.com",
  "bugs": {
    "url": "https://github.com/okrapdf/cli/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "dotenv": "^17.2.3",
    "enquirer": "^2.4.1",
    "form-data": "^4.0.0",
    "got": "^14.4.2",
    "mupdf": "^0.3.0",
    "ora": "^8.0.1",
    "sharp": "^0.33.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.5.0",
    "undici": "^6.21.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts.map",
    "README.md",
    "LICENSE"
  ]
}
